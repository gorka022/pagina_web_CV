---
import projects from '../data/projects.json';
---

<section id="projects" class="py-24 md:py-32 bg-white border-y border-surface-200">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section header -->
    <div class="mb-16" data-animate>
      <div class="flex items-center gap-4 mb-4">
        <h2 class="text-3xl md:text-4xl font-black text-surface-900 uppercase tracking-tight">Projects</h2>
        <div class="h-px flex-1 bg-surface-200"></div>
      </div>
      <p class="text-lg text-surface-600">Selection of academic projects and quantitative analysis. Click to view the source code.</p>
    </div>

    <!-- Project Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      {projects.map((project, index) => {
        const icons = [
          `<path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z" />`,
          `<path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m0-10.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.75c0 5.592 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.57-.598-3.75h-.152c-3.196 0-6.1-1.249-8.25-3.286zm0 13.036h.008v.008H12v-.008z" />`,
          `<path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18.75a60.07 60.07 0 0115.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 013 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 00-.75.75v.75m0 0H3.75m0 0h-.375a1.125 1.125 0 01-1.125-1.125V15m1.5 1.5v-.75A.75.75 0 003 15h-.75M15 10.5a3 3 0 11-6 0 3 3 0 016 0zm3 0h.008v.008H18V10.5zm-12 0h.008v.008H6V10.5z" />`,
          `<path stroke-linecap="round" stroke-linejoin="round" d="M3.75 3v11.25A2.25 2.25 0 006 16.5h2.25M3.75 3h-1.5m1.5 0h16.5m0 0h1.5m-1.5 0v11.25A2.25 2.25 0 0118 16.5h-2.25m-7.5 0h7.5m-7.5 0l-1 3m8.5-3l1 3m0 0l.5 1.5m-.5-1.5h-9.5m0 0l-.5 1.5M9 11.25v1.5M12 9v3.75m3-6v6" />`
        ];
        const iconPath = icons[index % icons.length];
        const hasCode = project.codeFiles && project.codeFiles.length > 0;
        const codeFilesJSON = hasCode ? JSON.stringify(project.codeFiles) : '[]';
        const fileCount = hasCode ? project.codeFiles.length : 0;

        return (
          <div
            class={`project-card group ${hasCode ? 'cursor-pointer' : ''}`}
            data-animate
            data-code-files={codeFilesJSON}
            data-code-lang={project.codeLang || ''}
            data-project-title={project.title}
            data-long-description={project.longDescription || ''}
            onclick={hasCode ? `openCodeModal(this.dataset.projectTitle, this.dataset.codeFiles, this.dataset.codeLang, this.dataset.longDescription)` : undefined}
          >
            <div class="glass rounded-sm overflow-hidden h-full flex flex-col border-t-4 border-t-primary-600">
              {/* Card content */}
              <div class="p-6 md:p-8 flex flex-col flex-1 relative">
                
                <div class="flex items-center justify-between gap-4 mb-4 mt-2">
                  <div class="w-12 h-12 rounded bg-primary-50 border border-primary-100 flex items-center justify-center text-primary-600">
                    <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" set:html={iconPath}></svg>
                  </div>
                  {hasCode && (
                    <span class="text-xs font-bold uppercase tracking-wider text-primary-600 bg-primary-50 px-3 py-1 rounded border border-primary-200 flex items-center gap-1.5 opacity-80 group-hover:opacity-100 transition-opacity">
                      <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" />
                      </svg>
                      {fileCount > 1 ? fileCount + ' Files' : 'Code'}
                    </span>
                  )}
                </div>

                <h3 class="text-xl font-bold text-surface-900 group-hover:text-primary-600 transition-colors mb-3">
                  {project.title}
                </h3>
                
                <p class="text-surface-600 leading-relaxed mb-6 flex-1 text-sm md:text-base">
                  {project.description}
                </p>

                {/* Tags (Only language) */}
                <div class="flex flex-wrap gap-2 pt-4 border-t border-surface-200 mt-auto">
                  {project.codeLang && (
                    <span class="px-2 py-1 rounded bg-surface-100 text-surface-600 text-xs font-semibold uppercase tracking-wider">
                      {project.codeLang}
                    </span>
                  )}
                </div>
              </div>
            </div>
          </div>
        );
      })}
    </div>
  </div>
</section>
