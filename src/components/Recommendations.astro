---
import recommendations from '../data/recommendations.json';
---

<section id="recommendations" class="py-24 md:py-32 bg-surface-50 text-surface-900 border-y border-surface-200">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section header -->
    <div class="mb-16" data-animate>
      <div class="flex items-center gap-4 mb-4">
        <h2 class="text-3xl md:text-4xl font-black text-surface-900 uppercase tracking-tight">Cartas de Recomendación</h2>
        <div class="h-px flex-1 bg-surface-200"></div>
      </div>
      <p class="text-lg text-surface-600">Reconocimientos de profesoras del Grado en ADE sobre mi desempeño académico y profesional.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      {recommendations.map((rec) => (
        <div class="glass p-8 rounded-sm relative group hover:border-primary-500 transition-all duration-300" data-animate>
          {/* Quote Icon Background */}
          <div class="absolute top-4 right-8 text-surface-100 group-hover:text-primary-50 transition-colors duration-300 -z-0">
            <svg class="w-16 h-16" fill="currentColor" viewBox="0 0 24 24">
              <path d="M14.017 21L14.017 18C14.017 16.8954 14.9124 16 16.017 16H19.017C19.5693 16 20.017 15.5523 20.017 15V9C20.017 8.44772 19.5693 8 19.017 8H16.017C15.4647 8 15.017 8.44772 15.017 9V12C15.017 12.5523 14.5693 13 14.017 13H13.017V21H14.017ZM6.017 21H7.017V13H6.017C5.46472 13 5.017 12.5523 5.017 12V9C5.017 8.44772 5.46472 8 6.017 8H9.017C9.56928 8 10.017 8.44772 10.017 9V15C10.017 15.5523 9.56928 16 9.017 16H6.017C4.91243 16 4.017 16.8954 4.017 18V21H6.017Z" />
            </svg>
          </div>

          <div class="relative z-10">
            <p class="text-surface-600 italic leading-relaxed mb-8 text-lg">
              "{rec.text}"
            </p>

            <div class="flex items-center gap-4">
              {rec.avatar && (
                <img src={rec.avatar} alt={rec.name} class="w-12 h-12 rounded-full object-cover border border-surface-200" />
              )}
              {!rec.avatar && (
                <div class="w-12 h-12 rounded bg-primary-100 flex items-center justify-center text-primary-600 font-bold text-xl border border-primary-200">
                  {rec.name.charAt(0)}
                </div>
              )}
              <div>
                <a 
                  href={rec.profileUrl} 
                  target="_blank" 
                  rel="noopener noreferrer"
                  class="text-surface-900 font-bold hover:text-primary-600 transition-colors flex items-center gap-1 group/link"
                >
                  {rec.name}
                  <svg class="w-3.5 h-3.5 opacity-0 group-hover/link:opacity-100 transition-opacity" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                  </svg>
                </a>
                <p class="text-primary-600 text-xs font-bold uppercase tracking-wider mb-0.5">{rec.role}</p>
                <p class="text-surface-500 text-xs font-medium">{rec.university}</p>
              </div>
            </div>

            {/* View PDF Button */}
            {rec.pdfUrl && (
              <div class="mt-8 pt-6 border-t border-surface-100 flex justify-end">
                <a 
                  href={rec.pdfUrl} 
                  target="_blank" 
                  class="inline-flex items-center gap-2 px-4 py-2 rounded-sm bg-primary-50 text-primary-600 hover:bg-primary-600 hover:text-white font-bold text-xs uppercase tracking-widest transition-all duration-300"
                >
                  <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z" />
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 9h1.5m1.5 0H13m-4 4h1.5m1.5 0H13m-4 4h1.5m1.5 0H13" />
                  </svg>
                  Ver PDF
                </a>
              </div>
            )}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .glass {
    background: white;
    border: 1px solid var(--color-surface-200);
    box-shadow: 0 1px 2px 0 rgb(0 0 0 / 0.05);
  }
  
  :global(.dark) .glass {
    background: var(--color-surface-850);
    border-color: var(--color-surface-700);
    box-shadow: none;
  }
</style>
