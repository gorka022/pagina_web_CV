---
import recommendations from "../data/recommendations.json";
---

<section
  id="recommendations"
  class="py-24 md:py-32 bg-surface-50 text-surface-900 border-y border-surface-200"
>
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section header -->
    <div class="mb-16" data-animate>
      <div class="flex items-center gap-4 mb-4">
        <h2
          class="text-3xl md:text-4xl font-black text-surface-900 uppercase tracking-tight"
        >
          Cartas de Recomendación
        </h2>
        <div class="h-px flex-1 bg-surface-200"></div>
      </div>
      <p class="text-lg text-surface-600">
        Cartas de recomendación de mi trayectoria académica.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      {
        recommendations.map((rec) => (
          <div
            class="glass p-6 rounded-sm relative group hover:border-primary-500 transition-all duration-300"
            data-animate
          >
            <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-6">
              <div class="flex items-center gap-4">
                {rec.avatar && (
                  <img
                    src={rec.avatar}
                    alt={rec.name}
                    class="w-12 h-12 rounded-full object-cover border border-surface-200"
                  />
                )}
                {!rec.avatar && (
                  <div class="w-12 h-12 rounded bg-primary-100 flex items-center justify-center text-primary-600 font-bold text-xl border border-primary-200">
                    {rec.name.charAt(0)}
                  </div>
                )}
                <div>
                  <a
                    href={rec.profileUrl}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-surface-900 font-bold hover:text-primary-600 transition-colors flex items-center gap-1 group/link"
                  >
                    {rec.name}
                    <svg
                      class="w-3.5 h-3.5 opacity-0 group-hover/link:opacity-100 transition-opacity"
                      fill="none"
                      viewBox="0 0 24 24"
                      stroke="currentColor"
                      stroke-width="2.5"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"
                      />
                    </svg>
                  </a>
                  <p class="text-primary-600 text-xs font-bold uppercase tracking-wider mb-0.5">
                    {rec.role}
                  </p>
                  <p class="text-surface-500 text-xs font-medium">
                    {rec.university}
                  </p>
                </div>
              </div>

              {/* View PDF Button */}
              {rec.pdfUrl && (
                <a
                  href={rec.pdfUrl}
                  target="_blank"
                  class="inline-flex items-center gap-2 px-4 py-2 rounded-sm bg-primary-50 text-primary-600 hover:bg-primary-600 hover:text-white font-bold text-xs uppercase tracking-widest transition-all duration-300 whitespace-nowrap"
                >
                  <svg
                    class="w-4 h-4"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    stroke-width="2"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      d="M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z"
                    />
                  </svg>
                  Ver PDF
                </a>
              )}
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .glass {
    background: white;
    border: 1px solid var(--color-surface-200);
    box-shadow: 0 1px 2px 0 rgb(0 0 0 / 0.05);
  }

  :global(.dark) .glass {
    background: var(--color-surface-850);
    border-color: var(--color-surface-700);
    box-shadow: none;
  }
</style>
