<!-- Code Modal — Shows project source code with syntax highlighting, file explorer, and download -->
<div id="code-modal" class="fixed inset-0 z-[100] hidden">
  <!-- Backdrop -->
  <div id="modal-backdrop" class="absolute inset-0 bg-surface-900/90 backdrop-blur-sm transition-opacity duration-300 opacity-0"></div>

  <!-- Modal container -->
  <div class="relative flex items-center justify-center min-h-screen p-4 sm:p-6">
    <div id="modal-content" class="relative w-full max-w-7xl max-h-[90vh] flex flex-col bg-surface-950 rounded-sm shadow-2xl border border-surface-800 overflow-hidden transform transition-all duration-300 scale-95 opacity-0">
      
      <!-- Header -->
      <div class="flex items-center justify-between px-5 py-4 border-b border-surface-800 bg-surface-900 flex-shrink-0">
        <div class="flex items-center gap-3 min-w-0">
          <!-- Language icon -->
          <span id="modal-lang-badge" class="inline-flex items-center gap-1.5 px-3 py-1 rounded bg-surface-800 border border-surface-700 text-surface-300 text-xs font-bold uppercase tracking-wide"></span>
          <h3 id="modal-title" class="text-lg font-bold text-white truncate"></h3>
          <!-- File count badge -->
          <span id="modal-file-count" class="hidden items-center gap-1 px-2 py-0.5 rounded bg-surface-800/60 border border-surface-700/50 text-surface-400 text-xs font-medium">
            <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12.75V12A2.25 2.25 0 014.5 9.75h15A2.25 2.25 0 0121.75 12v.75m-8.69-6.44l-2.12-2.12a1.5 1.5 0 00-1.061-.44H4.5A2.25 2.25 0 002.25 6v12a2.25 2.25 0 002.25 2.25h15A2.25 2.25 0 0021.75 18V9a2.25 2.25 0 00-2.25-2.25h-5.379a1.5 1.5 0 01-1.06-.44z" />
            </svg>
            <span id="modal-file-count-text"></span>
          </span>
        </div>
        <div class="flex items-center gap-2 flex-shrink-0">
          <!-- Copy button -->
          <button id="modal-copy-btn" class="p-2 rounded-sm text-surface-400 hover:bg-surface-800 transition-colors" title="Copy code">
            <svg id="copy-icon" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" />
            </svg>
            <svg id="check-icon" class="w-5 h-5 hidden text-emerald-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
            </svg>
          </button>
          <!-- Download button -->
          <a id="modal-download-btn" href="#" download class="inline-flex items-center gap-2 px-4 py-2 rounded-sm bg-primary-600 hover:bg-primary-500 text-white text-sm font-semibold transition-colors border border-primary-500">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
            </svg>
            <span class="hidden sm:inline">Download</span>
          </a>
          <!-- Close / Go Back button -->
          <button id="modal-close-btn" class="inline-flex items-center gap-2 px-4 py-2 rounded-sm bg-surface-800 hover:bg-surface-700 text-white text-sm font-semibold transition-colors border border-surface-700" title="Go Back">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
            </svg>
            <span>Go Back</span>
          </button>
        </div>
      </div>

      <!-- Main Content Split -->
      <div class="flex-1 overflow-hidden bg-surface-950 flex flex-col md:flex-row">
        
        <!-- Left Panel: Description + File Explorer -->
        <div class="flex-none md:flex-1 w-full md:w-1/3 flex flex-col border-b md:border-b-0 md:border-r border-surface-800 bg-surface-900/30">
          
          <!-- Description area -->
          <div class="p-6 md:p-8 border-b border-surface-800/50">
            <div class="max-w-prose">
              <h4 class="text-xs font-bold uppercase tracking-[0.2em] text-primary-500 mb-4 flex items-center gap-2">
                <span class="w-8 h-px bg-primary-500/30"></span>
                Project Overview
              </h4>
              <p id="modal-long-description" class="text-surface-200 leading-relaxed text-sm md:text-base whitespace-pre-line font-light italic">
              </p>
            </div>
          </div>

          <!-- File Explorer -->
          <div class="flex-1 overflow-y-auto p-4 md:p-6">
            <h4 class="text-xs font-bold uppercase tracking-[0.2em] text-surface-400 mb-4 flex items-center gap-2">
              <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12.75V12A2.25 2.25 0 014.5 9.75h15A2.25 2.25 0 0121.75 12v.75m-8.69-6.44l-2.12-2.12a1.5 1.5 0 00-1.061-.44H4.5A2.25 2.25 0 002.25 6v12a2.25 2.25 0 002.25 2.25h15A2.25 2.25 0 0021.75 18V9a2.25 2.25 0 00-2.25-2.25h-5.379a1.5 1.5 0 01-1.06-.44z" />
              </svg>
              Project Files
            </h4>
            <nav id="modal-file-list" class="space-y-1">
              <!-- File entries will be injected here -->
            </nav>
          </div>
        </div>

        <!-- Right Panel: Code area -->
        <div class="flex-1 w-full md:w-2/3 overflow-auto bg-surface-950 border-t md:border-t-0 border-surface-800">
          <!-- Loading state -->
          <div id="modal-loading" class="flex items-center justify-center py-20">
            <div class="flex items-center gap-3 text-surface-400">
              <svg class="w-6 h-6 animate-spin" fill="none" viewBox="0 0 24 24">
                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
              </svg>
              <span class="text-sm font-medium uppercase tracking-wider">Loading code...</span>
            </div>
          </div>
          <!-- Code content -->
          <div id="modal-code-wrapper" class="hidden h-full">
            <pre class="!m-0 !rounded-none !bg-surface-950 h-full"><code id="modal-code" class="text-xs sm:text-sm leading-relaxed !p-6 sm:!p-8 text-surface-200"></code></pre>
          </div>
          <!-- Error state -->
          <div id="modal-error" class="hidden flex items-center justify-center py-20">
            <div class="text-center text-surface-400">
              <svg class="w-12 h-12 mx-auto mb-3 opacity-50" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 11-18 0 9 9 0 0118 0zm-9 3.75h.008v.008H12v-.008z" />
              </svg>
              <p class="text-sm font-medium uppercase tracking-wider">Failed to load code</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Footer with file info -->
      <div class="px-5 py-3 border-t border-surface-800 bg-surface-900 flex-shrink-0">
        <p id="modal-file-info" class="text-xs text-surface-500 font-mono"></p>
      </div>
    </div>
  </div>
</div>

<style>
  @reference "../styles/global.css";

  /* Basic adjustments for Prism */
  #modal-code-wrapper pre {
    @apply m-0 rounded-none bg-surface-950 text-surface-100;
  }

  /* File explorer item styling */
  .file-explorer-item {
    @apply flex items-center gap-3 px-3 py-2.5 rounded cursor-pointer transition-all duration-150 text-surface-200 hover:bg-surface-800/60 hover:text-white font-medium w-full text-left;
  }
  .file-explorer-item.active {
    @apply bg-primary-600/20 text-primary-300 border-l-2 border-primary-500 font-semibold;
  }
  .file-explorer-item .file-icon {
    @apply w-5 h-5 flex-shrink-0 opacity-80;
  }
  .file-explorer-item.active .file-icon {
    @apply opacity-100 text-primary-400;
  }
  .file-explorer-item .file-name {
    @apply truncate font-sans text-sm tracking-wide flex-1 min-w-0;
  }
  .file-explorer-item .file-ext {
    @apply ml-3 text-xs uppercase tracking-wider opacity-70 font-bold flex-shrink-0;
  }
  .file-explorer-item.active .file-ext {
    @apply opacity-100 text-primary-400;
  }
</style>

<!-- Load Prism CSS & JS -->
<link href="https://cdnjs.cloudflare.com/ajax/libs/prism/1.29.0/themes/prism-tomorrow.min.css" rel="stylesheet" />
<script src="https://cdnjs.cloudflare.com/ajax/libs/prism/1.29.0/prism.min.js" is:inline></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/prism/1.29.0/components/prism-python.min.js" is:inline></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/prism/1.29.0/components/prism-r.min.js" is:inline></script>

<script is:inline>
(function() {
  const modal = document.getElementById('code-modal');
  const backdrop = document.getElementById('modal-backdrop');
  const content = document.getElementById('modal-content');
  const closeBtn = document.getElementById('modal-close-btn');
  const copyBtn = document.getElementById('modal-copy-btn');
  const copyIcon = document.getElementById('copy-icon');
  const checkIcon = document.getElementById('check-icon');
  const downloadBtn = document.getElementById('modal-download-btn');
  const title = document.getElementById('modal-title');
  const langBadge = document.getElementById('modal-lang-badge');
  const loading = document.getElementById('modal-loading');
  const codeWrapper = document.getElementById('modal-code-wrapper');
  const codeEl = document.getElementById('modal-code');
  const errorEl = document.getElementById('modal-error');
  const fileInfo = document.getElementById('modal-file-info');
  const longDescEl = document.getElementById('modal-long-description');
  const fileList = document.getElementById('modal-file-list');
  const fileCountBadge = document.getElementById('modal-file-count');
  const fileCountText = document.getElementById('modal-file-count-text');

  let currentCode = '';
  let currentFiles = [];
  let currentLang = '';

  const langConfig = {
    python: { label: 'Python', bg: 'bg-amber-100 dark:bg-amber-500/15 text-amber-700 dark:text-amber-400 border border-amber-200 dark:border-amber-500/20' },
    r: { label: 'R', bg: 'bg-blue-100 dark:bg-blue-500/15 text-blue-700 dark:text-blue-400 border border-blue-200 dark:border-blue-500/20' }
  };

  // Get file extension for icon styling
  function getFileExt(filename) {
    const parts = filename.split('.');
    return parts.length > 1 ? parts.pop() : '';
  }

  // Get language from file extension
  function getLangFromFile(filePath) {
    const ext = getFileExt(filePath);
    const langMap = { 'py': 'python', 'r': 'r', 'R': 'r', 'js': 'javascript', 'ts': 'typescript', 'sql': 'sql', 'sh': 'bash', 'md': 'markdown' };
    return langMap[ext] || currentLang || 'python';
  }

  // File icon SVG based on extension
  function getFileIconSVG(ext) {
    return '<svg class="file-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m2.25 0H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" /></svg>';
  }

  // Build the file explorer sidebar
  function buildFileExplorer(files, activeIndex) {
    fileList.innerHTML = '';
    files.forEach(function(file, idx) {
      const ext = getFileExt(file.label);
      const baseName = ext ? file.label.slice(0, -(ext.length + 1)) : file.label;
      const item = document.createElement('button');
      item.className = 'file-explorer-item' + (idx === activeIndex ? ' active' : '');
      item.innerHTML = getFileIconSVG(ext) +
        '<span class="file-name">' + baseName + '</span>' +
        (ext ? '<span class="file-ext">.' + ext + '</span>' : '');
      item.addEventListener('click', function() {
        loadFile(idx);
      });
      fileList.appendChild(item);
    });
  }

  // Load a specific file by index
  async function loadFile(index) {
    if (index < 0 || index >= currentFiles.length) return;

    const file = currentFiles[index];
    
    // Update active state in file explorer
    buildFileExplorer(currentFiles, index);

    // Show loading
    loading.classList.remove('hidden');
    codeWrapper.classList.add('hidden');
    errorEl.classList.add('hidden');
    currentCode = '';

    const fileName = file.path.split('/').pop();
    const fileLang = getLangFromFile(file.path);
    fileInfo.textContent = fileName;
    downloadBtn.href = file.path;
    downloadBtn.download = fileName;

    try {
      const response = await fetch(file.path);
      if (!response.ok) throw new Error('Failed to fetch');
      currentCode = await response.text();

      // Configure Prism
      codeEl.className = 'language-' + fileLang + ' text-sm leading-relaxed !p-5';
      codeEl.textContent = currentCode;
      if (window.Prism) {
        Prism.highlightElement(codeEl);
      }

      const lineCount = currentCode.split('\n').length;
      const sizeKB = (new Blob([currentCode]).size / 1024).toFixed(1);
      fileInfo.textContent = fileName + ' — ' + lineCount + ' lines · ' + sizeKB + ' KB';

      loading.classList.add('hidden');
      codeWrapper.classList.remove('hidden');
    } catch (e) {
      loading.classList.add('hidden');
      errorEl.classList.remove('hidden');
    }
  }

  // Open modal — now accepts codeFiles as a JSON string array
  window.openCodeModal = async function(projectTitle, codeFilesJSON, codeLang, longDescription) {
    currentCode = '';
    currentLang = codeLang;

    // Parse codeFiles
    try {
      currentFiles = JSON.parse(codeFilesJSON);
    } catch (e) {
      // Fallback: treat as single file path (backwards compat)
      currentFiles = [{ path: codeFilesJSON, label: codeFilesJSON.split('/').pop() }];
    }

    title.textContent = projectTitle;
    longDescEl.textContent = longDescription || '';
    const lc = langConfig[codeLang] || langConfig.python;
    langBadge.textContent = lc.label;
    langBadge.className = 'inline-flex items-center gap-1.5 px-3 py-1 rounded-lg text-xs font-bold uppercase tracking-wide ' + lc.bg;

    // Show file count badge if multiple files
    if (currentFiles.length > 1) {
      fileCountBadge.classList.remove('hidden');
      fileCountBadge.classList.add('inline-flex');
      fileCountText.textContent = currentFiles.length + ' files';
    } else {
      fileCountBadge.classList.add('hidden');
      fileCountBadge.classList.remove('inline-flex');
    }

    // Open modal
    modal.classList.remove('hidden');
    document.body.style.overflow = 'hidden';

    requestAnimationFrame(function() {
      backdrop.classList.remove('opacity-0');
      backdrop.classList.add('opacity-100');
      content.classList.remove('scale-95', 'opacity-0');
      content.classList.add('scale-100', 'opacity-100');
    });

    // Build file explorer and load first file
    buildFileExplorer(currentFiles, 0);
    await loadFile(0);
  };

  function closeModal() {
    backdrop.classList.remove('opacity-100');
    backdrop.classList.add('opacity-0');
    content.classList.remove('scale-100', 'opacity-100');
    content.classList.add('scale-95', 'opacity-0');

    setTimeout(function() {
      modal.classList.add('hidden');
      document.body.style.overflow = '';
    }, 300);
  }

  closeBtn.addEventListener('click', closeModal);
  backdrop.addEventListener('click', closeModal);
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape' && !modal.classList.contains('hidden')) {
      closeModal();
    }
  });

  copyBtn.addEventListener('click', async function() {
    if (!currentCode) return;
    try {
      await navigator.clipboard.writeText(currentCode);
      copyIcon.classList.add('hidden');
      checkIcon.classList.remove('hidden');
      setTimeout(function() {
        copyIcon.classList.remove('hidden');
        checkIcon.classList.add('hidden');
      }, 2000);
    } catch (e) {
      const ta = document.createElement('textarea');
      ta.value = currentCode;
      document.body.appendChild(ta);
      ta.select();
      document.execCommand('copy');
      document.body.removeChild(ta);
    }
  });
})();
</script>
