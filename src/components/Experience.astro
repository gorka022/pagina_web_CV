---
import experience from '../data/experience.json';
import profile from '../data/profile.json';
---

<section id="experience" class="py-24 md:py-32 bg-surface-50 text-surface-900 border-y border-surface-200">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section header -->
    <div class="mb-16" data-animate>
      <div class="flex items-center gap-4 mb-4">
        <h2 class="text-3xl md:text-4xl font-black text-surface-900 uppercase tracking-tight">Professional Experience</h2>
        <div class="h-px flex-1 bg-surface-200"></div>
      </div>
      <p class="text-lg text-surface-600">My academic and professional background in the world of finance.</p>
    </div>

    <!-- Legend -->
    <div class="flex flex-wrap items-center gap-6 mb-12" data-animate>
      <div class="flex items-center gap-2 text-sm">
        <span class="w-3 h-3 rounded-sm bg-primary-600"></span>
        <span class="text-surface-700 font-semibold uppercase tracking-wider text-xs">Education</span>
      </div>
      <div class="flex items-center gap-2 text-sm">
        <span class="w-3 h-3 rounded-sm bg-accent-500"></span>
        <span class="text-surface-700 font-semibold uppercase tracking-wider text-xs">Work Experience</span>
      </div>
    </div>

    <!-- Timeline -->
    <div class="relative">
      <!-- Vertical line -->
      <div class="timeline-line"></div>

      {experience.map((exp, index) => {
        const isWork = exp.type === 'work';
        const dotColor = isWork ? 'bg-accent-500' : 'bg-primary-600';
        const companyColor = isWork ? 'text-accent-600' : 'text-primary-700';
        const typeLabel = isWork ? 'Work' : 'Education';

        return (
          <div class="relative mb-12 last:mb-0" data-animate>
            {/* Timeline dot */}
            <div class={`absolute left-4 md:left-1/2 w-4 h-4 rounded-sm ${dotColor} border-2 border-white shadow-sm z-10`} style={`top: 1.5rem; transform: translate(-50%, 0);`}></div>

            {/* Card */}
            <div class={`ml-12 md:ml-0 md:w-[calc(50%-2rem)] ${index % 2 === 0 ? 'md:mr-auto' : 'md:ml-auto'}`}>
              <div class="glass rounded-sm p-6 md:p-8 hover:shadow-md transition-shadow duration-200 group border-l-4 border-l-transparent hover:border-l-primary-500">
                {/* Type + Period */}
                <div class="flex flex-wrap items-center gap-4 mb-3 text-xs font-bold uppercase tracking-wider text-surface-500">
                  <span class="flex items-center gap-1.5">
                    <span class={`w-2 h-2 rounded-sm ${dotColor}`}></span>
                    {typeLabel}
                  </span>
                  <span class="flex items-center gap-1.5 border-l border-surface-200 pl-4">
                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                    </svg>
                    {exp.period}
                  </span>
                </div>

                <h3 class="text-xl font-bold text-surface-900 mb-1 group-hover:text-primary-600 transition-colors">
                  {exp.role}
                </h3>
                <p class={`${companyColor} font-semibold mb-4 text-sm uppercase tracking-wide`}>
                  {exp.company}
                </p>
                <p class="text-surface-600 whitespace-pre-line leading-relaxed mb-6 text-sm md:text-base">
                  {exp.description}
                </p>

              </div>
            </div>
          </div>
        );
      })}
    </div>

    <!-- Skills and Languages (Moved from Hero) -->
    <div class="mt-24 border-t border-surface-200 pt-16" data-animate>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
        <!-- Tech stack pills -->
        <div>
          <div class="flex items-center gap-3 mb-6">
            <h3 class="text-xl font-bold text-surface-900 uppercase tracking-tight">Core Skills</h3>
            <div class="h-px flex-1 bg-surface-200"></div>
          </div>
          <div class="flex flex-wrap gap-2">
            {profile.skills.map((skill) => (
              <span class="px-3 py-1.5 rounded bg-surface-100 border border-surface-200 text-xs font-semibold text-surface-700 uppercase tracking-wider">
                {skill}
              </span>
            ))}
          </div>
        </div>

        <!-- Languages -->
        <div>
          <div class="flex items-center gap-3 mb-6">
            <h3 class="text-xl font-bold text-surface-900 uppercase tracking-tight">Languages</h3>
            <div class="h-px flex-1 bg-surface-200"></div>
          </div>
          <div class="flex flex-wrap gap-3">
            {profile.languages.map((lang) => (
              <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded bg-surface-100 border border-surface-200 text-xs font-semibold text-surface-700 uppercase tracking-wider">
                <svg class="w-3.5 h-3.5 text-accent-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3 5h12M9 3v2m1.048 9.5A18.022 18.022 0 016.412 9m6.088 9h7M11 21l5-10 5 10M12.751 5C11.783 10.77 8.07 15.61 3 18.129" />
                </svg>
                {lang.name}: {lang.level}
              </span>
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
